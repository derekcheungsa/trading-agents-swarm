# Required: OpenRouter API key for LLM model access
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Required: PostgreSQL connection string
# On Railway, set this to: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set automatically by Railway — do not change
# PORT=8080
# NODE_ENV=production
